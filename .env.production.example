# ===== Production environment for KI-Verkaufsberater =====
# Copy to `.env` on the server and fill in the marked lines.
# DO NOT COMMIT a filled-in copy.

# --- Public domain (used by Caddy for auto-HTTPS) ---
PUBLIC_DOMAIN=api.example.com
LETSENCRYPT_EMAIL=ops@example.com

# --- Application ---
ENVIRONMENT=production
LOG_LEVEL=INFO
API_VERSION=0.1.0

# --- Postgres (used by both backend and the postgres container) ---
POSTGRES_USER=ki
POSTGRES_DB=ki
# REPLACE: 32+ random chars
POSTGRES_PASSWORD=CHANGE_ME_to_a_long_random_string

# --- Admin ---
# REPLACE: 32+ random chars. Required for POST /v1/shops.
ADMIN_API_KEY=CHANGE_ME_to_a_long_random_string

# --- LLM provider keys ---
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
OPENAI_API_KEY=

# --- Stripe Billing ---
STRIPE_API_KEY=
STRIPE_WEBHOOK_SECRET=
# Price-IDs aus dem Stripe Dashboard (eines pro Plan, Subscription-Product)
STRIPE_PRICE_STARTER=
STRIPE_PRICE_GROWTH=
STRIPE_PRICE_PRO=
STRIPE_PRICE_ENTERPRISE=
# URLs für Stripe Checkout-Redirects (optional, sonst Defaults)
STRIPE_SUCCESS_URL=https://api.example.com/billing/success
STRIPE_CANCEL_URL=https://api.example.com/billing/cancel

# --- DSGVO retention ---
RETENTION_DAYS=90
RETENTION_LOOP_ENABLED=1

# --- Rate limiting ---
RATE_LIMIT_DEFAULT=100/minute
# Internal compose hostname; overridden by docker-compose env to redis://redis:6379/1
RATE_LIMIT_STORAGE_URI=redis://redis:6379/1

# --- Sentry (leave SENTRY_DSN empty to disable) ---
SENTRY_DSN=
# 0 = no APM tracing, 0.1 = 10% sample rate, 1.0 = trace all (expensive)
SENTRY_TRACES_SAMPLE_RATE=0
SENTRY_ENVIRONMENT=production

---
<section class="relative isolate overflow-hidden">
  <div class="absolute inset-0 -z-10 bg-gradient-to-b from-brand-50 via-white to-white"></div>
  <div class="mx-auto max-w-6xl px-6 pt-20 pb-24 md:pt-28 md:pb-32">
    <div class="max-w-3xl">
      <span class="inline-flex items-center gap-2 rounded-full bg-brand-100 text-brand-700 text-xs font-medium px-3 py-1">
        <span class="size-2 rounded-full bg-brand-600 animate-pulse"></span>
        Geschlossene Beta · Q2 2026
      </span>
      <h1 class="mt-5 text-4xl md:text-6xl font-bold tracking-tight leading-[1.05]">
        Berater im Shop.<br>
        <span class="text-brand-600">Live, immer da, DSGVO-konform.</span>
      </h1>
      <p class="mt-6 text-lg md:text-xl text-slate-600 max-w-2xl">
        Endkunden stellen Fragen, KI-Berater antwortet aus Eurem
        Produktkatalog — in Echtzeit, mit konkreten Empfehlungen.
        Mehr Conversion, weniger abgebrochene Karten.
      </p>
      <div class="mt-8 flex flex-wrap gap-4">
        <a href="#cta"
           class="bg-brand-600 hover:bg-brand-700 text-white px-6 py-3 rounded-lg font-medium shadow-sm">
          Beta-Anmeldung
        </a>
        <a href="#how"
           class="bg-white hover:bg-slate-50 border border-slate-300 px-6 py-3 rounded-lg font-medium">
          Wie funktioniert's? →
        </a>
      </div>
      <div class="mt-10 grid grid-cols-2 md:grid-cols-3 gap-x-8 gap-y-3 text-sm text-slate-600">
        <div class="flex items-center gap-2">
          <svg class="w-4 h-4 text-brand-600" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 0 1 .143 1.052l-8 10.5a.75.75 0 0 1-1.127.075l-4.5-4.5a.75.75 0 1 1 1.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 0 1 1.05-.143Z" clip-rule="evenodd" />
          </svg>
          Hosting in Deutschland
        </div>
        <div class="flex items-center gap-2">
          <svg class="w-4 h-4 text-brand-600" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 0 1 .143 1.052l-8 10.5a.75.75 0 0 1-1.127.075l-4.5-4.5a.75.75 0 1 1 1.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 0 1 1.05-.143Z" clip-rule="evenodd" />
          </svg>
          Echtzeit-Produkt-Sync
        </div>
        <div class="flex items-center gap-2">
          <svg class="w-4 h-4 text-brand-600" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 0 1 .143 1.052l-8 10.5a.75.75 0 0 1-1.127.075l-4.5-4.5a.75.75 0 1 1 1.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 0 1 1.05-.143Z" clip-rule="evenodd" />
          </svg>
          Conversion-Tracking inkludiert
        </div>
      </div>
    </div>
  </div>
</section>

---
import type { Lang } from "../../data/brand";

interface Props {
  lang: Lang;
  /** Current page slug, e.g. "/" or "/b" or "/deck" — passed to compute the mirror */
  path: string;
}

const { lang, path } = Astro.props;

function mirror(p: string, target: Lang): string {
  const cleaned = p.replace(/\/$/, "") || "/";
  if (target === "en") {
    if (cleaned === "/") return "/en/";
    if (cleaned.startsWith("/en")) return cleaned;
    return `/en${cleaned}`;
  }
  // target = de
  if (cleaned === "/en" || cleaned === "/en/") return "/";
  if (cleaned.startsWith("/en/")) return cleaned.slice(3);
  return cleaned;
}

const deHref = mirror(path, "de");
const enHref = mirror(path, "en");
---

<div
  class="no-print"
  style="
    position: fixed; top: 14px; right: 14px;
    display: flex; gap: 4px; padding: 4px;
    background: rgba(255,255,255,0.85); backdrop-filter: blur(10px);
    border: 1px solid var(--color-line);
    border-radius: 100px;
    font-family: var(--font-mono);
    font-size: 11px;
    z-index: 50;
  "
>
  <a
    href={deHref}
    style={`padding: 4px 10px; border-radius: 100px; text-decoration: none; ${lang === "de" ? "background: var(--color-ink); color: #fff;" : "color: var(--color-ink-2);"}`}
  >DE</a>
  <a
    href={enHref}
    style={`padding: 4px 10px; border-radius: 100px; text-decoration: none; ${lang === "en" ? "background: var(--color-ink); color: #fff;" : "color: var(--color-ink-2);"}`}
  >EN</a>
</div>

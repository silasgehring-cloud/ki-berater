---
const steps = [
  {
    n: "1",
    title: "Plugin installieren",
    body: "Plugin im WordPress-Backend hochladen + aktivieren. Backend-URL und API-Key eintragen.",
  },
  {
    n: "2",
    title: "Katalog synchronisieren",
    body: "Ein Klick auf „Alle Produkte synchronisieren" — fertig. Echtzeit-Webhook hält's danach aktuell.",
  },
  {
    n: "3",
    title: "Widget geht live",
    body: "Floating-Bubble unten rechts in eurem Shop. Endkunden öffnen, fragen, bekommen Empfehlungen.",
  },
  {
    n: "4",
    title: "Conversion messen",
    body: "Conversion-Tracking läuft automatisch. Settings-Page zeigt: Gespräche, Conversions, Umsatz, LLM-Kosten.",
  },
];
---
<section id="how" class="py-20 md:py-28">
  <div class="mx-auto max-w-6xl px-6">
    <div class="max-w-2xl">
      <h2 class="text-3xl md:text-4xl font-bold tracking-tight">
        In 10 Minuten live
      </h2>
      <p class="mt-4 text-lg text-slate-600">
        Keine Schulung, keine Beratung, keine APIs zu lernen. Plugin rein, Key
        rein, fertig.
      </p>
    </div>
    <ol class="mt-12 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
      {steps.map((s) => (
        <li class="rounded-xl border border-slate-200 bg-white p-6">
          <div class="size-10 rounded-full bg-brand-600 text-white grid place-items-center font-bold">
            {s.n}
          </div>
          <h3 class="mt-4 text-lg font-semibold">{s.title}</h3>
          <p class="mt-2 text-slate-600 text-sm leading-relaxed">{s.body}</p>
        </li>
      ))}
    </ol>
  </div>
</section>

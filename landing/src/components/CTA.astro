---
---
<section id="cta" class="py-20 md:py-28 bg-gradient-to-br from-brand-600 to-brand-700 text-white">
  <div class="mx-auto max-w-3xl px-6 text-center">
    <h2 class="text-3xl md:text-4xl font-bold tracking-tight">
      Beta-Anmeldung
    </h2>
    <p class="mt-4 text-lg text-brand-100">
      Wir nehmen aktuell 5–10 Pilot-Shops auf. Ersten 3 Monate gratis,
      danach regulärer Plan-Preis. Kein Lock-in.
    </p>
    <form class="mt-8 flex flex-col sm:flex-row gap-3 max-w-lg mx-auto"
          action="mailto:hello@ki-berater.de"
          method="get"
          enctype="text/plain">
      <input
        type="email"
        name="from"
        placeholder="dein.shop@example.com"
        required
        class="flex-1 px-4 py-3 rounded-lg text-slate-900 bg-white placeholder:text-slate-400 focus:outline-none focus:ring-4 focus:ring-white/30"
      />
      <button
        type="submit"
        class="bg-white hover:bg-brand-50 text-brand-700 font-semibold px-6 py-3 rounded-lg shadow-sm">
        Anmelden →
      </button>
    </form>
    <p class="mt-4 text-sm text-brand-100">
      Wir antworten persönlich innerhalb von 48 Stunden.
    </p>
  </div>
</section>

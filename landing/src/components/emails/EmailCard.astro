---
import { buildEmail, type EmailVariant } from "./email-content";
import { BRAND, ACCENT, fillName, type Lang } from "../../data/brand";

interface Props {
  variant: EmailVariant;
  lang?: Lang;
  name?: string;
  accent?: string;
}

const { variant, lang = "de", name = BRAND, accent = ACCENT } = Astro.props;
const isDe = lang === "de";
const e = buildEmail(variant, { lang, name });
const senderName = isDe ? "[Ihr Name]" : "[Your name]";
const initial = (name[0] ?? "k").toLowerCase();
const subjectFilled = fillName(e.subject, name);

function partsForLine(line: string): Array<{ text: string; bold: boolean }> {
  if (!line.includes("__NAME__")) return [{ text: line, bold: false }];
  const segs = line.split("__NAME__");
  const out: Array<{ text: string; bold: boolean }> = [];
  segs.forEach((s, i) => {
    if (s) out.push({ text: s, bold: false });
    if (i < segs.length - 1) out.push({ text: name, bold: true });
  });
  return out;
}
---

<div
  class="kit-root"
  style={`width: 520px; max-width: 100%; height: 680px; background: #fff; --accent: ${accent}; display: flex; flex-direction: column; font-size: 13px; border: 1px solid var(--color-line); border-radius: var(--radius); overflow: hidden;`}
>
  {/* Mail header */}
  <div style="padding: 14px 20px; background: var(--color-bg-soft); border-bottom: 1px solid var(--color-line-soft);">
    <div style="display: flex; align-items: center; gap: 10px; margin-bottom: 6px;">
      <span class="chip chip-accent" style="font-size: 10px;">{e.label}</span>
      <span class="mono" style="font-size: 10px; color: var(--color-ink-3);">{isDe ? "ENTWURF" : "DRAFT"}</span>
    </div>
    <div style="font-size: 16px; font-weight: 500; line-height: 1.3;">{subjectFilled}</div>
  </div>

  <div style="padding: 14px 20px; border-bottom: 1px solid var(--color-line-soft); display: grid; grid-template-columns: 70px 1fr; gap: 8px; font-size: 12px; color: var(--color-ink-2);">
    <div style="color: var(--color-ink-3);">{isDe ? "Von" : "From"}</div>
    <div>{senderName} &lt;{isDe ? "ihr.name" : "your.name"}@{name.toLowerCase()}.io&gt;</div>
    <div style="color: var(--color-ink-3);">{isDe ? "An" : "To"}</div>
    <div>{isDe ? "[Vorname Nachname]" : "[First name Last name]"} &lt;[email]&gt;</div>
  </div>

  <div style="padding: 20px 24px; flex: 1; font-size: 13px; line-height: 1.55; color: var(--color-ink); overflow: auto;">
    {e.body.map((line) => (
      <div style={`margin-bottom: ${line === "" ? "12px" : "0"}; min-height: ${line === "" ? "0" : "1.55em"};`}>
        {partsForLine(line).map((p) => (p.bold ? <strong>{p.text}</strong> : <Fragment>{p.text}</Fragment>))}
      </div>
    ))}

    {/* Signature */}
    <div style="margin-top: 18px; padding-top: 14px; border-top: 1px solid var(--color-line-soft); display: flex; align-items: center; gap: 10px;">
      <span class="logo-mark" style="width: 28px; height: 28px; font-size: 16px;">{initial}</span>
      <div>
        <div style="font-weight: 500; font-size: 12px;">{senderName} · {name}</div>
        <div class="mono" style="font-size: 10px; color: var(--color-ink-3);">{name.toLowerCase()}.io · {isDe ? "Demo buchen" : "Book a demo"}</div>
      </div>
    </div>
  </div>

  <div class="no-print" style="padding: 10px 20px; border-top: 1px solid var(--color-line-soft); display: flex; gap: 8px;">
    <button class="btn btn-primary" style="font-size: 12px; padding: 7px 14px;">{isDe ? "Senden" : "Send"} →</button>
    <button class="btn btn-secondary" style="font-size: 12px; padding: 7px 14px;">{isDe ? "Speichern" : "Save"}</button>
  </div>
</div>

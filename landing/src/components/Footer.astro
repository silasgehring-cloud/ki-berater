---
const year = new Date().getFullYear();
---
<footer class="bg-slate-900 text-slate-400 text-sm">
  <div class="mx-auto max-w-6xl px-6 py-12 grid grid-cols-2 md:grid-cols-4 gap-8">
    <div class="col-span-2">
      <a href="/" class="font-bold text-white text-base flex items-center gap-2">
        <span class="inline-block w-7 h-7 rounded-lg bg-brand-600 grid place-items-center text-sm">KI</span>
        KI-Berater
      </a>
      <p class="mt-3 max-w-sm">
        KI-Verkaufsberater für WooCommerce-Shops. Gebaut in Deutschland,
        gehostet in Deutschland, gesetzeskonform aus Deutschland.
      </p>
    </div>
    <div>
      <h4 class="text-white font-semibold mb-3">Produkt</h4>
      <ul class="space-y-2">
        <li><a href="#features" class="hover:text-white">Features</a></li>
        <li><a href="#pricing" class="hover:text-white">Preise</a></li>
        <li><a href="#how" class="hover:text-white">So geht's</a></li>
      </ul>
    </div>
    <div>
      <h4 class="text-white font-semibold mb-3">Rechtliches</h4>
      <ul class="space-y-2">
        <li><a href="/impressum" class="hover:text-white">Impressum</a></li>
        <li><a href="/datenschutz" class="hover:text-white">Datenschutz</a></li>
        <li><a href="/agb" class="hover:text-white">AGB</a></li>
        <li><a href="mailto:security@ki-berater.de" class="hover:text-white">Security Disclosure</a></li>
      </ul>
    </div>
  </div>
  <div class="border-t border-slate-800">
    <div class="mx-auto max-w-6xl px-6 py-4 flex flex-col md:flex-row justify-between gap-3 text-xs">
      <span>© {year} KI-Berater. Alle Rechte vorbehalten.</span>
      <span>
        <a href="mailto:hello@ki-berater.de" class="hover:text-white">hello@ki-berater.de</a>
      </span>
    </div>
  </div>
</footer>

---
const features = [
  {
    title: "Produktwissen aus Eurem Katalog",
    body:
      "Vector-Search auf Name, Beschreibung, Kategorien. Kein generisches Bullshit-Bingo — der Berater empfiehlt genau die Artikel, die ihr im Lager habt.",
    icon: "📦",
  },
  {
    title: "DSGVO konform aus Frankfurt",
    body:
      "Hosting bei Hetzner Frankfurt. AVV mit allen LLM-Anbietern. Auto-Retention nach 90 Tagen. Data-Export-Endpoint für Auskunftsanfragen.",
    icon: "🇪🇺",
  },
  {
    title: "Mehr Umsatz, messbar",
    body:
      "Conversion-Tracking pro Conversation. Strict-Attribution wenn Empfehlung = Bestellung. Du siehst sofort: ‚3.420 € Umsatz aus 28 Chats diesen Monat.‘",
    icon: "📈",
  },
  {
    title: "Echtzeit-Sync aus WooCommerce",
    body:
      "Plugin sendet jedes Produkt-Update via signiertem Webhook. Neuer Artikel im Shop → 30 Sekunden später vom Berater empfehlbar.",
    icon: "⚡",
  },
  {
    title: "Streaming-Antworten",
    body:
      "Wörter erscheinen live im Chat — wie ChatGPT. Kein Spinner-Warten, kein Bounce.",
    icon: "💬",
  },
  {
    title: "Mehrere LLM-Provider",
    body:
      "Heuristisches Routing zwischen Gemini Flash und Claude Sonnet. Standardfragen günstig, komplexe Beratung gut. Marge unter Kontrolle.",
    icon: "🧠",
  },
];
---
<section id="features" class="py-20 md:py-28">
  <div class="mx-auto max-w-6xl px-6">
    <div class="max-w-2xl">
      <h2 class="text-3xl md:text-4xl font-bold tracking-tight">
        Gebaut für ernsthafte Shops
      </h2>
      <p class="mt-4 text-lg text-slate-600">
        Kein Generic-Chatbot. Kein „Wir können auch was mit AI machen". Ein
        Werkzeug, das deine Conversion-Rate misst und beweist.
      </p>
    </div>
    <div class="mt-12 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {features.map((f) => (
        <div class="rounded-xl border border-slate-200 bg-white p-6 hover:border-brand-500 hover:shadow-md transition">
          <div class="text-3xl">{f.icon}</div>
          <h3 class="mt-4 text-lg font-semibold">{f.title}</h3>
          <p class="mt-2 text-slate-600 text-sm leading-relaxed">{f.body}</p>
        </div>
      ))}
    </div>
  </div>
</section>

* text=auto eol=lf

# Force LF on files that run in Linux containers / shells
*.sh         text eol=lf
*.py         text eol=lf
Dockerfile   text eol=lf
Makefile     text eol=lf
*.yml        text eol=lf
*.yaml       text eol=lf
*.neon       text eol=lf

# Force CRLF on Windows batch / PowerShell — cmd.exe miscompiles LF-only.
*.bat        text eol=crlf
*.cmd        text eol=crlf
*.ps1        text eol=crlf

# Treat as binary
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.zip  binary

{
    "name": "ki-berater/woocommerce-plugin",
    "description": "WordPress plugin for KI-Verkaufsberater (KI-Chatbot for WooCommerce).",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "require": {
        "php": ">=8.0",
        "yahnis-elsts/plugin-update-checker": "^5.6"
    },
    "require-dev": {
        "phpstan/phpstan": "^1.12",
        "szepeviktor/phpstan-wordpress": "^1.3",
        "phpunit/phpunit": "^10.5",
        "wp-coding-standards/wpcs": "^3.1",
        "squizlabs/php_codesniffer": "^3.10"
    },
    "scripts": {
        "lint": "phpstan analyse --memory-limit=1G",
        "test": "phpunit",
        "cs": "phpcs --standard=WordPress includes/ ki-berater.php"
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    }
}

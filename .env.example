# Application
ENVIRONMENT=development
LOG_LEVEL=INFO
API_VERSION=0.1.0

# Database
DATABASE_URL=postgresql+asyncpg://ki:ki@localhost:5432/ki

# Redis
REDIS_URL=redis://localhost:6379/0

# Qdrant
QDRANT_URL=http://localhost:6333

# LLM Provider keys (Sprint 1.2 onwards)
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
OPENAI_API_KEY=

# Stripe (Phase 4)
STRIPE_API_KEY=
STRIPE_WEBHOOK_SECRET=

# Admin (for shop provisioning endpoint)
ADMIN_API_KEY=

# CORS (comma-separated origins, "*" for dev only)
CORS_ALLOW_ORIGINS=*

# Rate limiting (slowapi syntax: "<count>/<period>")
RATE_LIMIT_DEFAULT=100/minute
# Empty = in-memory (dev/CI). Production: set to redis://host:6379/1
RATE_LIMIT_STORAGE_URI=
